{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Martingale Backtest Config",
  "type": "object",
  "required": [
    "symbols", "timeframe", "date_from", "date_to",
    "initial_balance_usd", "total_wallet_exposure",
    "strategy", "output"
  ],
  "properties": {
    "symbols": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]{2,10}USDT$" },
      "minItems": 1
    },
    "timeframe": {
      "type": "string",
      "enum": ["1m", "5m", "15m", "30m", "1h", "4h", "12h", "1d"]
    },
    "date_from": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "date_to": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "initial_balance_usd": { "type": "number", "minimum": 1 },
    "total_wallet_exposure": { "type": "number", "minimum": 0.1 },
    "strategy": {
      "type": "object",
      "required": [
        "entry_ema_period", "entry_ema_distance_pct",
        "entry_grid_spacing_pct", "initial_qty_pct",
        "double_down_factor", "close_grid_spacing_pct",
        "close_grid_count", "sl_upnl_pct", "n_positions",
        "parkinson_volatility_span", "maker_fee_pct"
      ],
      "properties": {
        "entry_ema_period": { "type": "integer", "minimum": 2 },
        "entry_ema_distance_pct": { "type": "number", "minimum": 0 },
        "entry_grid_spacing_pct": { "type": "number", "minimum": 0 },
        "initial_qty_pct": { "type": "number", "minimum": 0, "maximum": 1 },
        "double_down_factor": { "type": "number", "minimum": 0 },
        "close_grid_spacing_pct": { "type": "number", "minimum": 0 },
        "close_grid_count": { "type": "integer", "minimum": 1 },
        "sl_upnl_pct": { "type": "number", "maximum": 0 },
        "n_positions": { "type": "integer", "minimum": 1 },
        "parkinson_volatility_span": { "type": "integer", "minimum": 2 },
        "maker_fee_pct": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "optimize": {
      "type": "object",
      "properties": {
        "n_workers": { "type": "integer", "minimum": 0 },
        "limits": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" }
            },
            "minProperties": 1
          }
        },
        "scoring": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "weight"],
            "properties": {
              "metric": { "type": "string" },
              "weight": { "type": "number", "minimum": 0 }
            }
          }
        },
        "bounds": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 3
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["dir"],
      "properties": {
        "dir": { "type": "string" }
      }
    }
  }
}
